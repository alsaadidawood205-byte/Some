-- تشغيل المحادثة (WebSocket)
local function StartWS()
    local Http = game:GetService("HttpService")
    local ws = WebSocket.connect("wss://free.blr2.piesocket.com/v3/1?api_key=eLudeCBiiTiQSr6DWJPMPfpZK9B6ghEu90ZbJwzm&notify_self=1")
    
    input.FocusLost:Connect(function(enter)
        if enter and input.Text ~= "" then
            ws:Send(Http:JSONEncode({
                username = LocalPlayer.Name,
                message = input.Text,
                jobid = game.JobId
            }))
            input.Text = ""
        end
    end)

    ws.OnMessage:Connect(function(msg)
        local data = Http:JSONDecode(msg)
        if data.jobid ~= game.JobId then return end
        local m = Instance.new("TextLabel", chatFrame)
        m.Size = UDim2.new(1, 0, 0, 20)
        m.Text = data.username .. ": " .. data.message
        m.TextColor3 = Color3.fromRGB(255, 255, 255)
        m.BackgroundTransparency = 1
        m.TextXAlignment = Enum.TextXAlignment.Left
    end)
end

